local function createESP(plr)
	if plr == LP then return end
	if cache[plr] then return end

	local d = {
		box = Drawing.new("Square"),
		line = Drawing.new("Line"),
		name = Drawing.new("Text"),
		dist = Drawing.new("Text"),
		hp = Drawing.new("Square"),
		skel = {}
	}

	d.box.Filled = false
	d.box.Thickness = 2

	d.line.Thickness = 2
	d.hp.Filled = true

	for _,t in pairs({d.name,d.dist}) do
		t.Size = 13
		t.Center = true
		t.Outline = true
	end

	for i=1,14 do
		local l = Drawing.new("Line")
		l.Thickness = 2
		table.insert(d.skel,l)
	end

	cache[plr] = d
end

for _,p in pairs(Players:GetPlayers()) do
	createESP(p)
end

Players.PlayerAdded:Connect(createESP)

local function hide(d)
	for _,v in pairs({d.box,d.line,d.name,d.dist,d.hp}) do
		v.Visible = false
	end
	for _,l in pairs(d.skel) do
		l.Visible = false
	end
end

local function bone(char,a,b,line,col)
	local p1 = char:FindFirstChild(a)
	local p2 = char:FindFirstChild(b)

	if p1 and p2 then
		local v1,on1 = Camera:WorldToViewportPoint(p1.Position)
		local v2,on2 = Camera:WorldToViewportPoint(p2.Position)

		if on1 and on2 then
			line.Visible = true
			line.From = Vector2.new(v1.X,v1.Y)
			line.To = Vector2.new(v2.X,v2.Y)
			line.Color = col
			return
		end
	end

	line.Visible = false
end

