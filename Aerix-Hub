-- LOOP
--========================
RunService.RenderStepped:Connect(function()

	for plr,d in pairs(cache) do

		local char = plr.Character
		local hum = char and char:FindFirstChildOfClass("Humanoid")
		local hrp = char and char:FindFirstChild("HumanoidRootPart")

		if espEnabled and char and hum and hrp and hum.Health > 0 and LP.Character and LP.Character:FindFirstChild("HumanoidRootPart") then

			local dist = (LP.Character.HumanoidRootPart.Position - hrp.Position).Magnitude

			if dist <= setOpt.MaxDistance then

				local pos,vis = Camera:WorldToViewportPoint(hrp.Position)

				if vis then

					local size = math.clamp(2200/dist,18,140)

					-- BOX
					d.box.Visible = drawOpt.Box
					d.box.Size = Vector2.new(size,size*1.5)
					d.box.Position = Vector2.new(pos.X-size/2,pos.Y-size*0.75)
					d.box.Color = colorOpt.Box

					-- LINE
					d.line.Visible = drawOpt.Line
					d.line.From = setOpt.LineMode=="Top"
						and Vector2.new(Camera.ViewportSize.X/2,0)
						or Vector2.new(Camera.ViewportSize.X/2,Camera.ViewportSize.Y)

					d.line.To = Vector2.new(pos.X,pos.Y)
					d.line.Color = colorOpt.Line

					-- NAME
					d.name.Visible = drawOpt.Name
					d.name.Text = plr.Name
					d.name.Position = Vector2.new(pos.X,pos.Y-size)
					d.name.Color = colorOpt.Name

					-- DISTANCE
					d.dist.Visible = drawOpt.Distance
					d.dist.Text = math.floor(dist).."m"
					d.dist.Position = Vector2.new(pos.X,pos.Y+size)
					d.dist.Color = colorOpt.Distance

					-- HP BAR
					local hp = hum.Health / hum.MaxHealth
					local hpColor = Color3.fromRGB(0,255,0)

					if hp <= 0.5 then
						hpColor = Color3.fromRGB(255,255,0)
					end
					if hp <= 0.25 then
						hpColor = Color3.fromRGB(255,0,0)
					end

					d.hp.Visible = drawOpt.Health
					d.hp.Color = hpColor

					if setOpt.HPMode == "Side" then
						d.hp.Size = Vector2.new(4,(size*1.5)*hp)
						d.hp.Position = Vector2.new(pos.X-size/2-6,pos.Y+size*0.75-d.hp.Size.Y)
					else
						d.hp.Size = Vector2.new(size*hp,4)
						d.hp.Position = Vector2.new(pos.X-size/2,pos.Y-size*0.85)
					end

					-- HIGHLIGHT
					if drawOpt.Highlight then
						if not char:FindFirstChild("ESP_H") then
							local h = Instance.new("Highlight",char)
							h.Name = "ESP_H"
							h.FillTransparency = 0.6
						end

						char.ESP_H.Enabled = true
						char.ESP_H.FillColor = colorOpt.Highlight
						char.ESP_H.OutlineColor = colorOpt.Highlight
					else
						if char:FindFirstChild("ESP_H") then
							char.ESP_H.Enabled = false
						end
					end

					-- SKELETON
					if drawOpt.Skeleton then
						bone(char,"Head","UpperTorso",d.skel[1],colorOpt.Skeleton)
						bone(char,"UpperTorso","LowerTorso",d.skel[2],colorOpt.Skeleton)

						bone(char,"UpperTorso","LeftUpperArm",d.skel[3],colorOpt.Skeleton)
						bone(char,"LeftUpperArm","LeftLowerArm",d.skel[4],colorOpt.Skeleton)
						bone(char,"LeftLowerArm","LeftHand",d.skel[5],colorOpt.Skeleton)

						bone(char,"UpperTorso","RightUpperArm",d.skel[6],colorOpt.Skeleton)
						bone(char,"RightUpperArm","RightLowerArm",d.skel[7],colorOpt.Skeleton)
						bone(char,"RightLowerArm","RightHand",d.skel[8],colorOpt.Skeleton)

						bone(char,"LowerTorso","LeftUpperLeg",d.skel[9],colorOpt.Skeleton)
						bone(char,"LeftUpperLeg","LeftLowerLeg",d.skel[10],colorOpt.Skeleton)
						bone(char,"LeftLowerLeg","LeftFoot",d.skel[11],colorOpt.Skeleton)

						bone(char,"LowerTorso","RightUpperLeg",d.skel[12],colorOpt.Skeleton)
						bone(char,"RightUpperLeg","RightLowerLeg",d.skel[13],colorOpt.Skeleton)
						bone(char,"RightLowerLeg","RightFoot",d.skel[14],colorOpt.Skeleton)
					else
						for _,l in pairs(d.skel) do
							l.Visible = false
						end
					end

				else
					hide(d)
				end
			else
				hide(d)
			end
		else
			hide(d)
		end
	end
end)
